# Пример конфига для backup-db.sh.
# Скопируйте в /etc/backup-pg.conf и раскомментируйте нужные параметры —
# они переопределят значения по умолчанию из скрипта.

# Каталог бинарников PostgreSQL; пусто или не задано = брать из PATH.
# Для Postgres Pro 1C:
#PGBIN="/opt/pgpro/1c-14/bin"

# Файл со списком БД для бэкапа (по одной на строку, # — комментарий)
#BASES="/var/lib/pgpro/scripts/DB"

# Каталог логов
#LOGS="/var/lib/pgpro/service_logs"

# Каталог бэкапов
#BACKUPDIR="/var/lib/backup/pgpro"

# Сколько последних бэкапов хранить для каждой БД
#KEEP=28

# Сколько дней хранить логи
#LOGKEEP_DAYS=60

# Файл-отметка для мониторинга (обновляется при успешном завершении)
#TIMESTAMP_FILE="/var/log/timestamp"
