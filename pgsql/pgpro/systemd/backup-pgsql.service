[Unit]
Description=Backup and maintenance PostgreSQL DB
Wants=postgrespro-1c-18.service
After=postgrespro-1c-18.service

[Service]
Type=oneshot
# Запуск от root: скрипт сам переключается на postgres через su - postgres.
ExecStart=/var/lib/pgpro/_backup/scripts/wal-g-manager.sh backup-all
Environment="PATH=/sbin:/bin:/usr/sbin:/usr/bin"

[Install]
WantedBy=multi-user.target
